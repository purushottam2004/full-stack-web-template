# Copy this file to `.env` and fill in values.

# --- Supabase ---
# Your project URL (Project Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Secret role key (Project Settings → API → secret key)
# Keep this secret and NEVER expose it to frontend clients.
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY

# Publishable key (Project Settings → API →  publishable key)
# Safe to use in clients; used by tests to sign in.
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY


# -- AI Providers --
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- App ---
# DEPLOYMENT_ENV can be PRODUCTION or STAGE or LOCAL
DEPLOYMENT_ENV=PRODUCTION
LOGGING_LEVEL=INFO